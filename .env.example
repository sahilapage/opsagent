# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key

# ── Vector DB (Qdrant) ────────────────────────────────────────────────────────
# Local (docker-compose)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Qdrant Cloud (set these to override local; get from cloud.qdrant.io)
# QDRANT_URL=https://xxxx.us-east-1-0.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your_qdrant_cloud_api_key

QDRANT_COLLECTION=opsagent_knowledge

# Embeddings cache directory (optional — defaults to system cache)
# FASTEMBED_CACHE_DIR=/tmp/fastembed

# ── PostgreSQL (long-term memory) ─────────────────────────────────────────────
# Local (docker-compose)
DATABASE_URL=postgresql://opsagent:opsagent_secret@localhost:5432/opsagent

# Railway PostgreSQL plugin: copy the DATABASE_URL Railway provides
# DATABASE_URL=postgresql://postgres:xxxx@monorail.proxy.rlwy.net:PORT/railway

# ── Google OAuth (Gmail / Calendar / Drive) ──────────────────────────────────
# Run `python3 auth_google.py` locally to generate token.json
# For Railway/production: paste the full contents of token.json here
# GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","scopes":[...]}

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_pat
GITHUB_DEFAULT_REPO=username/repo

# ── Web search (Browser agent) ────────────────────────────────────────────────
SERPER_API_KEY=your_serper_api_key

# ── Observability ─────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=opsagent

# ── Voice (optional) ──────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
WHISPER_MODEL=base

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
